FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        binutils \
        ca-certificates \
        g++-aarch64-linux-gnu \
        make \
        pkg-config \
        python3 \
        rsync \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace
